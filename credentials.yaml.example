# Chat2GO Agent — 凭证配置
# 拷贝到 ~/.chat2go/credentials.yaml 后填入实际 key。
# 优先级：环境变量 > 这个文件

anthropic:
  api_key: sk-ant-xxx

# OpenAI 协议兼容厂商共用一个 adapter，base_url 区分
openai:
  api_key: sk-xxx
  base_url: https://api.openai.com/v1

# 国产模型（OpenAI 协议兼容）
deepseek:
  api_key: sk-xxx
  base_url: https://api.deepseek.com/v1

qwen:
  api_key: sk-xxx
  base_url: https://dashscope.aliyuncs.com/compatible-mode/v1

kimi:
  api_key: sk-xxx
  base_url: https://api.moonshot.cn/v1

glm:
  api_key: xxx
  base_url: https://open.bigmodel.cn/api/paas/v4

# Gemini 协议特殊，自有 adapter
gemini:
  api_key: xxx

# OpenRouter（元提供商，可选）
# openrouter:
#   api_key: sk-or-xxx
#   base_url: https://openrouter.ai/api/v1

# 默认模型（房间没指定时用这个）
defaults:
  model: anthropic/claude-sonnet-4-5
