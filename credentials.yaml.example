# Chat2GO Agent — 凭证配置
# 拷贝到 ~/.chat2go/credentials.yaml 后填入实际 key。
# 优先级：环境变量 > 这个文件

# ── Chat2GO 连接密钥（大咖在 chat2go.cn 网页生成）──
# 推荐用 `chat2go-agent connect <你的 key>` 自动写入，不用手动填
# chat2go:
#   connection_key: c2g-key_a1b2c3d4...

anthropic:
  api_key: sk-ant-xxx

# OpenAI 协议兼容厂商共用一个 adapter，base_url 区分
openai:
  api_key: sk-xxx
  base_url: https://api.openai.com/v1

# 国产模型（OpenAI 协议兼容）
deepseek:
  api_key: sk-xxx
  base_url: https://api.deepseek.com/v1

qwen:
  api_key: sk-xxx
  base_url: https://dashscope.aliyuncs.com/compatible-mode/v1

kimi:
  api_key: sk-xxx
  base_url: https://api.moonshot.cn/v1

glm:
  api_key: xxx
  base_url: https://open.bigmodel.cn/api/paas/v4

# Gemini 协议特殊，自有 adapter
gemini:
  api_key: xxx

# OpenRouter（元提供商，可选）
# openrouter:
#   api_key: sk-or-xxx
#   base_url: https://openrouter.ai/api/v1

# 本地模型（Ollama 等，OpenAI 协议兼容；通常无需 api_key）
# 成本由大咖自报：硬件 + 电费分摊到每 1M token，单位 USD
# local:
#   base_url: http://localhost:11434/v1
#   models:
#     qwen2.5-72b:
#       input_per_mtok: 0.10        # 大咖估算
#       output_per_mtok: 0.10
#     llama-3-70b:
#       input_per_mtok: 0.05
#       output_per_mtok: 0.05

# 默认值（房间没指定时用这些）
defaults:
  model: anthropic/claude-sonnet-4-5
  commission_pct: 0.15        # 大咖佣金率（小白付 = 成本 × 1.15 × 汇率）
  exchange_rate: 7.20         # USD → CNY 汇率（手动锁，避免日内波动）
  brain: auto                 # 'auto' | 'builtin' | 'hermes'
                              # auto: 装了 hermes 用 hermes，否则 builtin
                              # builtin: chat2go 自己组装 prompt + 调 LLM
                              # hermes: shell out 到本地 hermes，复用 ~/.hermes 配置
