+async def _send_chat2go(pconfig, chat_id, message):
+    """
+    Send a message to a Chat2GO room.
+    Uses Chat2GoAdapter to handle connection_key → Supabase session → message insert.
+    """
+    try:
+        from gateway.platforms.chat2go import Chat2GoAdapter
+    except ImportError as e:
+        return _error(f"Chat2GO adapter import failed: {e}")
+
+    if not pconfig or not pconfig.token:
+        return _error("Chat2GO: CHAT2GO_TOKEN 未配置")
+
+    try:
+        adapter = Chat2GoAdapter(pconfig)
+        ok = await adapter.connect()
+        if not ok:
+            return _error("Chat2GO: 连接失败（看 hermes log 了解原因）")
+        try:
+            result = await adapter.send(chat_id=str(chat_id), content=message)
+        finally:
+            await adapter.disconnect()
+
+        if result.success:
+            return {
+                "success": True,
+                "platform": "chat2go",
+                "chat_id": chat_id,
+                "message_id": result.message_id,
+            }
+        return _error(f"Chat2GO send failed: {result.error}")
+    except Exception as e:
+        return _error(f"Chat2GO send failed: {e}")
+
+
