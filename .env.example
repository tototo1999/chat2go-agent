# Chat2GO Agent — 环境变量
#
# 优先级：环境变量 > ~/.chat2go/credentials.yaml
# 这里放的 key 会覆盖 yaml 文件里的同名 key，方便临时调试。

# ── Anthropic Claude（默认必备）──
ANTHROPIC_API_KEY=sk-ant-xxx

# ── OpenAI 协议兼容厂商（任选）──
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# QWEN_API_KEY=sk-xxx
# KIMI_API_KEY=sk-xxx
# GLM_API_KEY=xxx

# ── Gemini ──
# GEMINI_API_KEY=xxx

# ── OpenRouter（元提供商，未启用）──
# OPENROUTER_API_KEY=sk-or-xxx
